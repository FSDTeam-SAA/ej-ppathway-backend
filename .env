# Multi-currency — default country (ISO-3166 alpha-2) when geo/user country unknown
DEFAULT_COUNTRY=US

# LiveKit (use the same key/secret in deploy/livekit.yaml + deploy/egress.yaml)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-livekit-host.livekit.cloud

# Session recording storage — backend auto-detects:
#   * if EGRESS_S3_* below are set -> egress uploads directly to S3 (recordingUrl = S3 url)
#   * else if Cloudinary is set    -> egress writes locally, backend uploads to Cloudinary
#   * else                         -> served from RECORDING_PUBLIC_BASE_URL
# Local (Cloudinary) path: must match the egress volume mount in deploy/docker-compose.yml
EGRESS_OUTPUT_DIR=/recordings
# Optional S3-compatible storage (AWS S3 / MinIO / Cloudflare R2 / Wasabi)
EGRESS_S3_ACCESS_KEY=
EGRESS_S3_SECRET=
EGRESS_S3_BUCKET=
EGRESS_S3_REGION=us-east-1
EGRESS_S3_ENDPOINT=
EGRESS_S3_FORCE_PATH_STYLE=true
# Public base URL for streaming recordings (S3/local fallback; not needed for Cloudinary)
RECORDING_PUBLIC_BASE_URL=

# Default Super Admin (seed)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@propheticpathway.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_PHONE=+10000000000

# Platform Defaults
PLATFORM_DEFAULT_COMMISSION=20
WALLET_MIN_WITHDRAWAL=50
SESSION_LOW_BALANCE_THRESHOLD_MIN=2
