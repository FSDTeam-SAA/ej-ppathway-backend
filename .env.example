# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
# Advisor dashboard base URL — used to build the contract signing link in the
# "Send Contract" email + notification. Prod: https://ej-ppathway-advisor-dashboard.vercel.app
ADVISOR_DASHBOARD_URL=http://localhost:3001
SERVER_URL=http://localhost:5000

# Frontend and email action URLs
# Public website base URL. Used as fallback for public email links.
PUBLIC_SITE_URL=http://localhost:3002
WEBSITE_URL=http://localhost:3002
# Exact advisor dashboard URLs used in profile/welcome emails.
ADVISOR_LOGIN_URL=http://localhost:3001/login
ADVISOR_PROFILE_URL=http://localhost:3001/profile
# Exact public website pages used by advisor pipeline emails.
CONTRACT_SIGN_URL=http://localhost:3002/contract/sign
ONBOARDING_URL=http://localhost:3002/join-as-advisor/apply
# Base URL for live interview links; backend appends /advisor/interview/:applicationId.
INTERVIEW_URL=http://localhost:3000
# Base URL for session reschedule links; backend appends /sessions/:sessionId.
SESSION_RESCHEDULE_URL=http://localhost:3002

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/prophetic_pathway

# Background jobs
# The Mongo-backed job worker is enabled by default. It handles retryable tasks
# like large notification broadcasts without blocking API requests.
JOB_WORKER_ENABLED=true
JOB_WORKER_CONCURRENCY=2
JOB_WORKER_POLL_MS=1000
JOB_MAX_ATTEMPTS=3
NOTIFICATION_BROADCAST_BATCH_SIZE=500

# JWT
JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_strong_secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_RESET_SECRET=replace_with_reset_secret
JWT_RESET_EXPIRES_IN=15m

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Cloudflare R2 / S3-compatible object storage for all uploads
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=contents-public
R2_PRIVATE_BUCKET=contents-private
R2_BUCKET=contents-public
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_FORCE_PATH_STYLE=true
# Public/custom domain for reading uploaded files, e.g. https://media.example.com
R2_PUBLIC_BASE_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Prophetic Pathway <no-reply@propheticpathway.com>

# Stripe (no webhook — using success route flow)
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_PUBLISHABLE_KEY=pk_test_replace
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_WALLET_SUCCESS_URL=http://localhost:5000/api/v1/wallet/topup/success
STRIPE_WALLET_CANCEL_URL=http://localhost:5000/api/v1/wallet/topup/cancel
STRIPE_SUBSCRIPTION_SUCCESS_URL=http://localhost:5000/api/v1/subscriptions/checkout/success
STRIPE_SUBSCRIPTION_CANCEL_URL=http://localhost:5000/api/v1/subscriptions/checkout/cancel

# PayPal (REST Orders v2 — success route flow, same as Stripe)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WALLET_SUCCESS_URL=http://localhost:5000/api/v1/wallet/paypal/success
PAYPAL_WALLET_CANCEL_URL=http://localhost:5000/api/v1/wallet/paypal/cancel
PAYPAL_SUBSCRIPTION_SUCCESS_URL=http://localhost:5000/api/v1/subscriptions/paypal/success
PAYPAL_SUBSCRIPTION_CANCEL_URL=http://localhost:5000/api/v1/subscriptions/paypal/cancel

# Hyperwallet (advisor payouts — REST v4, Basic auth)
# Credentials come from the Hyperwallet program portal. Advisor earnings are held
# in credits and converted to USD at the configurable payout rate (admin dashboard
# → Payouts → Settings) before money is sent.
HYPERWALLET_MODE=sandbox
# Store real values only in .env or your deployment secret manager.
# PROGRAM_TOKEN funds payments; USER_PROGRAM_TOKEN owns payee profiles.
HYPERWALLET_USERNAME=your_hyperwallet_api_username
HYPERWALLET_PASSWORD=your_hyperwallet_api_password
HYPERWALLET_PROGRAM_TOKEN=prg_your_funding_program_token
HYPERWALLET_USER_PROGRAM_TOKEN=prg_your_payee_subprogram_token
# Optional shared secret; if set, Hyperwallet must send it as the Authorization header.
HYPERWALLET_WEBHOOK_SECRET=

# Multi-currency
# Default country (ISO-3166 alpha-2) when geolocation/user country is unknown.
DEFAULT_COUNTRY=US

# LiveKit (use the same key/secret in deploy/livekit.yaml + deploy/egress.yaml)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-livekit-host.livekit.cloud

# Session recording storage. LiveKit egress reuses R2_* above by default and
# writes recordings directly to R2/S3. Set EGRESS_S3_* only to override it.
EGRESS_OUTPUT_DIR=/recordings
EGRESS_S3_ACCESS_KEY=
EGRESS_S3_SECRET=
EGRESS_S3_BUCKET=
EGRESS_S3_REGION=auto
EGRESS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
EGRESS_S3_FORCE_PATH_STYLE=true
RECORDING_PUBLIC_BASE_URL=

# Default Super Admin (seed)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@propheticpathway.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_PHONE=+10000000000

# Platform Defaults
PLATFORM_DEFAULT_COMMISSION=20
WALLET_MIN_WITHDRAWAL=50
SESSION_LOW_BALANCE_THRESHOLD_MIN=2
