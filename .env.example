# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/prophetic_pathway

# JWT
JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_strong_secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_RESET_SECRET=replace_with_reset_secret
JWT_RESET_EXPIRES_IN=15m

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Prophetic Pathway <no-reply@propheticpathway.com>

# Stripe (no webhook — using success route flow)
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_PUBLISHABLE_KEY=pk_test_replace
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_WALLET_SUCCESS_URL=http://localhost:5000/api/v1/wallet/topup/success
STRIPE_WALLET_CANCEL_URL=http://localhost:5000/api/v1/wallet/topup/cancel
STRIPE_SUBSCRIPTION_SUCCESS_URL=http://localhost:5000/api/v1/subscriptions/checkout/success
STRIPE_SUBSCRIPTION_CANCEL_URL=http://localhost:5000/api/v1/subscriptions/checkout/cancel

# PayPal (REST Orders v2 — success route flow, same as Stripe)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WALLET_SUCCESS_URL=http://localhost:5000/api/v1/wallet/paypal/success
PAYPAL_WALLET_CANCEL_URL=http://localhost:5000/api/v1/wallet/paypal/cancel
PAYPAL_SUBSCRIPTION_SUCCESS_URL=http://localhost:5000/api/v1/subscriptions/paypal/success
PAYPAL_SUBSCRIPTION_CANCEL_URL=http://localhost:5000/api/v1/subscriptions/paypal/cancel

# Multi-currency
# Default country (ISO-3166 alpha-2) when geolocation/user country is unknown.
DEFAULT_COUNTRY=US

# LiveKit (use the same key/secret in deploy/livekit.yaml + deploy/egress.yaml)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-livekit-host.livekit.cloud

# Session recording storage — backend auto-detects S3 -> Cloudinary -> local.
EGRESS_OUTPUT_DIR=/recordings
EGRESS_S3_ACCESS_KEY=
EGRESS_S3_SECRET=
EGRESS_S3_BUCKET=
EGRESS_S3_REGION=us-east-1
EGRESS_S3_ENDPOINT=
EGRESS_S3_FORCE_PATH_STYLE=true
RECORDING_PUBLIC_BASE_URL=

# Default Super Admin (seed)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@propheticpathway.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_PHONE=+10000000000

# Platform Defaults
PLATFORM_DEFAULT_COMMISSION=20
WALLET_MIN_WITHDRAWAL=50
SESSION_LOW_BALANCE_THRESHOLD_MIN=2
